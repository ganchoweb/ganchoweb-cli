{
  "name": "@ganchoweb/cli",
  "version": "0.0.4",
  "description": "CLI do GanchoWeb: túnel autenticado em tempo real de webhooks para o app local.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ganchoweb/ganchoweb-cli.git"
  },
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "ganchoweb": "./dist/bin.js"
  },
  "main": "./dist/lib.js",
  "types": "./dist/lib.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsx watch src/bin.ts",
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "biome check .",
    "check:fix": "biome check --write ."
  },
  "dependencies": {
    "@clack/prompts": "^1.6.0",
    "@ganchoweb/core": "^0.1.0",
    "commander": "^15.0.0",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@types/node": "^22.10.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
